APP_NAME=AI-Powered Certificate Management System
API_V1_PREFIX=/api
MONGO_URI=mongodb://localhost:27017/certificate_management
MONGO_DB=certificate_management
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
